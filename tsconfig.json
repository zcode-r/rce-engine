{
  "compilerOptions": {
    "target": "ES2022",         /* Modern JS output */
    "module": "NodeNext",       /* Required for modern Node.js */
    "moduleResolution": "NodeNext",
    // "rootDir": "./src",         /* Where your source code lives */
    "outDir": "./dist",         /* Where the compiled JS will go */
    "strict": true,             /* Enable all strict type-checking options */
    "esModuleInterop": true,    /* Compatibility between CommonJS and ES Modules */
    "skipLibCheck": true,       /* Speed up compilation */
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*","prisma.config.ts"],
  "exclude": ["node"]
}